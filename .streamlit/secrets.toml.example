# 复制本文件为 secrets.toml，填入真实值，不要提交 secrets.toml 到 Git
# Streamlit Cloud 用户：在 App Settings -> Secrets 粘贴以下配置

[llm]
api_key   = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
base_url  = "https://api.openai.com/v1"   # 也可换成 Azure/Qwen/ZhipuAI 等兼容端点
model     = "gpt-4o-mini"

[weixin]
webhook_url = "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

[feishu]
webhook_url = "https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
